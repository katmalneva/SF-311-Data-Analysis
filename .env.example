# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=sf311_data
MONGODB_COLLECTION=cases

# Google Cloud Storage Configuration
GCS_PROJECT_ID=your_gcp_project_id
GCS_BUCKET_NAME=your_311_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# Apache Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///./airflow/airflow.db

# Dash Configuration
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=True

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Data Source Configuration
SF_311_API_ENDPOINT=https://data.sfgov.org/api/v3/views/vw6y-z8j6/query.json
SF_311_APP_TOKEN=your_socrata_app_token_here

# PySpark Configuration (optional)
PYSPARK_PYTHON=python3
SPARK_LOCAL_DIRS=./tmp/spark

# General Configuration
ENV=development
LOG_LEVEL=INFO
